KVERSIONS = @KNAME@
KMOD_REL=@LINUX_DISTRO@@UEK_MAJOR@u@UEK_MINOR@@UEK_KVER@
KARCH := $(shell uname -m)
FSTYPE=ext2

export

.PHONY: all prepare clean

all: prepare
	$(MAKE) -f Build.rules diskiso
	gunzip images/dd.iso.gz
	mv images/dd.iso images/fnic-@FNIC_VERSION@-$(KMOD_REL)@KNAME_PKGNAME@-dd.iso
	@echo -e "\nfnic driver disk built successfully!"
	@echo -e "ISO is images/fnic-@FNIC_VERSION@-$(KMOD_REL)-dd.iso\n"

prepare: clean
ifeq ($(KMOD_REL), unsupported)
	$(error "fnic driver disk cannot be built for this unsupported distribution")
endif
	chown -R $(shell whoami):$(shell id -gn) *

clean:
	$(MAKE) -f Build.rules distclean
