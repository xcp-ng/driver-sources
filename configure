    # does not support retpoline, abort.
    if test $vic_gcc_retpoline -eq 0 && test "$enable_compile_without_retpoline" = "no"; then :
  { $as_echo "$as_me:${as_lineno-$LINENO}: WARNING: gcc does not support retpoline (i.e.: $retpoline_flags)" >&5
$as_echo "$as_me: WARNING: gcc does not support retpoline (i.e.: $retpoline_flags)" >&2;}
	   { $as_echo "$as_me:${as_lineno-$LINENO}: WARNING: and --disable-compile-without-retpoline was specified," >&5
$as_echo "$as_me: WARNING: and --disable-compile-without-retpoline was specified," >&2;}
	   { $as_echo "$as_me:${as_lineno-$LINENO}: WARNING: so we are aborting." >&5
$as_echo "$as_me: WARNING: so we are aborting." >&2;}
	   as_fn_error $? "Cannot continue" "$LINENO" 5
fi

    # If gcc supports retpoline, see if each of them are already in
    # CFLAGS.  If not, add them to EXTRA_KCFLAGS.
    VIC_EXTRA_KCFLAGS=
    if test $vic_gcc_retpoline -eq 1; then :
  for flag in $retpoline_cflags; do
               if test -z "`echo $CFLAGS_save | grep -- $flag`"; then :
  VIC_EXTRA_KCFLAGS="$flag $VIC_EXTRA_KCFLAGS"
fi
           done

fi


