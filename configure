			if test $VIC_BUILDDIR_NEEDED -eq 1 -a -d "$build_dir/$rel_dir"; then :
  VIC_KERNEL_CPPFLAGS="$VIC_KERNEL_CPPFLAGS -I$build_dir/$rel_dir"
