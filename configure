    # Check whether --enable-compile-without-retpoline was given.
if test "${enable_compile_without_retpoline+set}" = set; then :
  enableval=$enable_compile_without_retpoline;
fi


    # See if gcc supports retpoline CLI options
    { $as_echo "$as_me:${as_lineno-$LINENO}: checking if gcc supports retpoline CLI options" >&5
$as_echo_n "checking if gcc supports retpoline CLI options... " >&6; }
    CFLAGS_save=$CFLAGS
    retpoline_cflags="-mindirect-branch=thunk-inline -mindirect-branch-register"
    CFLAGS="$CFLAGS $retpoline_cflags"






    CPPFLAGS_save=$CPPFLAGS
    CPPFLAGS=$VIC_KERNEL_CPPFLAGS

    cat confdefs.h - <<_ACEOF >conftest.$ac_ext
/* end confdefs.h.  */

int
main ()
{

int i = 0;
  ;
  return 0;
}
_ACEOF
if ac_fn_c_try_compile "$LINENO"; then :
  vic_gcc_retpoline=1
		        { $as_echo "$as_me:${as_lineno-$LINENO}: result: yes" >&5
$as_echo "yes" >&6; }
else
  vic_gcc_retpoline=0
		        { $as_echo "$as_me:${as_lineno-$LINENO}: result: no" >&5
$as_echo "no" >&6; }
fi
rm -f core conftest.err conftest.$ac_objext conftest.$ac_ext

