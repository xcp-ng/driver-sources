    # Register the CLI params


# Check whether --with-swims-ticket-file was given.
if test "${with_swims_ticket_file+set}" = set; then :
  withval=$with_swims_ticket_file;
fi



# Check whether --with-swims-key-type was given.
if test "${with_swims_key_type+set}" = set; then :
  withval=$with_swims_key_type;
fi



# Check whether --with-swims-signing-script was given.
if test "${with_swims_signing_script+set}" = set; then :
  withval=$with_swims_signing_script;
fi



    # See if the user intends to sign

    { $as_echo "$as_me:${as_lineno-$LINENO}: checking if digitally signing the .ko driver" >&5
$as_echo_n "checking if digitally signing the .ko driver... " >&6; }

    # Check to make sure both or neither of --with-swims-ticket-file
    # and --with-swims-signing-script were specified.
    vic_swims_cli_happy=1
    if test -n "$with_swims_ticket_file" -a -z "$with_swims_signing_script"; then :
  vic_swims_cli_happy=0
fi
    if test -z "$with_swims_ticket_file" -a -n "$with_swims_signing_script"; then :
  vic_swims_cli_happy=0
fi
    if test $vic_swims_cli_happy -eq 0; then :
  { $as_echo "$as_me:${as_lineno-$LINENO}: result: confusion" >&5
$as_echo "confusion" >&6; }
	   { $as_echo "$as_me:${as_lineno-$LINENO}: WARNING: If --with-swims-ticket-file is specified, --with-swims-signing-script must also be specified (and vice versa)" >&5
$as_echo "$as_me: WARNING: If --with-swims-ticket-file is specified, --with-swims-signing-script must also be specified (and vice versa)" >&2;}
	   as_fn_error $? "Cannot continue" "$LINENO" 5
fi

    # If both CLI options were specified, sanity check them
    if test -n "$with_swims_ticket_file" -a -n "$with_swims_signing_script"; then :
  { $as_echo "$as_me:${as_lineno-$LINENO}: result: yes" >&5
$as_echo "yes" >&6; }
	   vic_swims_happy=1
else
  { $as_echo "$as_me:${as_lineno-$LINENO}: result: no" >&5
$as_echo "no" >&6; }
	   vic_swims_happy=0
fi


    # If all was good, do final setups
    if test $vic_swims_happy -eq 1; then :

    # Check for the SWIMS ticket file
    { $as_echo "$as_me:${as_lineno-$LINENO}: checking for SWIMS ticket file" >&5
$as_echo_n "checking for SWIMS ticket file... " >&6; }
    file=`readlink -f $with_swims_ticket_file`
    if test ! -r "$file"; then :
  { $as_echo "$as_me:${as_lineno-$LINENO}: result: not found" >&5
$as_echo "not found" >&6; }
         { $as_echo "$as_me:${as_lineno-$LINENO}: WARNING: Cannot read $with_swims_ticket_file" >&5
$as_echo "$as_me: WARNING: Cannot read $with_swims_ticket_file" >&2;}
         as_fn_error $? "Cannot continue" "$LINENO" 5
         { $as_echo "$as_me:${as_lineno-$LINENO}: result: $file" >&5
$as_echo "$file" >&6; }

fi
    VIC_SWIMS_TICKET_FILE=$file
    { $as_echo "$as_me:${as_lineno-$LINENO}: result: $VIC_SWIMS_TICKET_FILE" >&5
$as_echo "$VIC_SWIMS_TICKET_FILE" >&6; }


    # Check for the SWIMS key type
    { $as_echo "$as_me:${as_lineno-$LINENO}: checking SWIMS key type" >&5
$as_echo_n "checking SWIMS key type... " >&6; }
    if test -z "$with_swims_key_type"; then :
  with_swims_key_type=DEV
fi
    case $with_swims_key_type in #(
  DEV) :
    VIC_SWIMS_KEY_TYPE=DEV ;; #(
  RELEASE) :
    VIC_SWIMS_KEY_TYPE=RELEASE ;; #(
  REV) :
    VIC_SWIMS_KEY_TYPE=REV ;; #(
  *) :
    { $as_echo "$as_me:${as_lineno-$LINENO}: WARNING: --with-swims-key-type must be one of DEV, RELEASE, or REV" >&5
$as_echo "$as_me: WARNING: --with-swims-key-type must be one of DEV, RELEASE, or REV" >&2;}
                        as_fn_error $? "Cannot continue" "$LINENO" 5 ;; #(
  *) :
     ;;
esac
    { $as_echo "$as_me:${as_lineno-$LINENO}: result: $VIC_SWIMS_KEY_TYPE" >&5
$as_echo "$VIC_SWIMS_KEY_TYPE" >&6; }


    # If we're signing, then we need an absolute directory location
    # for the signing script (because it's not included in the
    # tarball, and we'll need it to make binary packages).  If we were
    # given a relative filename, canonicalize it.
    { $as_echo "$as_me:${as_lineno-$LINENO}: checking for signing script" >&5
$as_echo_n "checking for signing script... " >&6; }
    if test ! -x "$with_swims_signing_script"; then :
  { $as_echo "$as_me:${as_lineno-$LINENO}: result: Cannot read $with_swims_signing_script, or it is not executable" >&5
$as_echo "Cannot read $with_swims_signing_script, or it is not executable" >&6; }
         as_fn_error $? "Cannot continue" "$LINENO" 5

fi

    # Turn the signing script filename into an absolute filename
    VIC_SWIMS_SIGNING_SCRIPT=`readlink -f $with_swims_signing_script`
    { $as_echo "$as_me:${as_lineno-$LINENO}: result: $VIC_SWIMS_SIGNING_SCRIPT" >&5
$as_echo "$VIC_SWIMS_SIGNING_SCRIPT" >&6; }


fi
    if test $vic_swims_happy -eq 1; then :

    for ac_prog in python python3 python2
do
  # Extract the first word of "$ac_prog", so it can be a program name with args.
set dummy $ac_prog; ac_word=$2
{ $as_echo "$as_me:${as_lineno-$LINENO}: checking for $ac_word" >&5
$as_echo_n "checking for $ac_word... " >&6; }
if ${ac_cv_prog_VIC_SWIMS_PYTHON+:} false; then :
  $as_echo_n "(cached) " >&6
else
  if test -n "$VIC_SWIMS_PYTHON"; then
  ac_cv_prog_VIC_SWIMS_PYTHON="$VIC_SWIMS_PYTHON" # Let the user override the test.
else
as_save_IFS=$IFS; IFS=$PATH_SEPARATOR
for as_dir in $PATH
do
  IFS=$as_save_IFS
  test -z "$as_dir" && as_dir=.
    for ac_exec_ext in '' $ac_executable_extensions; do
  if as_fn_executable_p "$as_dir/$ac_word$ac_exec_ext"; then
    ac_cv_prog_VIC_SWIMS_PYTHON="$ac_prog"
    $as_echo "$as_me:${as_lineno-$LINENO}: found $as_dir/$ac_word$ac_exec_ext" >&5
    break 2
  fi
done
  done
IFS=$as_save_IFS

fi
fi
VIC_SWIMS_PYTHON=$ac_cv_prog_VIC_SWIMS_PYTHON
if test -n "$VIC_SWIMS_PYTHON"; then
  { $as_echo "$as_me:${as_lineno-$LINENO}: result: $VIC_SWIMS_PYTHON" >&5
$as_echo "$VIC_SWIMS_PYTHON" >&6; }
else
  { $as_echo "$as_me:${as_lineno-$LINENO}: result: no" >&5
$as_echo "no" >&6; }
fi


  test -n "$VIC_SWIMS_PYTHON" && break
done

    if test -z "$VIC_SWIMS_PYTHON"; then :
  { $as_echo "$as_me:${as_lineno-$LINENO}: WARNING: requested crypto signing, but cannot find Python" >&5
$as_echo "$as_me: WARNING: requested crypto signing, but cannot find Python" >&2;}
         as_fn_error $? "Cannot continue" "$LINENO" 5

fi


fi
    if test $vic_swims_happy -eq 1; then :

    # Generate a string to pass in to package building
    VIC_SWIMS_CONFIGURE_CLI_OPTIONS="--with-swims-ticket-file=$VIC_SWIMS_TICKET_FILE"
    VIC_SWIMS_CONFIGURE_CLI_OPTIONS="$VIC_SWIMS_CONFIGURE_CLI_OPTIONS --with-swims-key-type=$VIC_SWIMS_KEY_TYPE"
    VIC_SWIMS_CONFIGURE_CLI_OPTIONS="$VIC_SWIMS_CONFIGURE_CLI_OPTIONS --with-swims-signing-script=$VIC_SWIMS_SIGNING_SCRIPT"


fi



#
# Checks needed for the VIC common code
#
ac_ext=c
ac_cpp='$CPP $CPPFLAGS'
ac_compile='$CC -c $CFLAGS $CPPFLAGS conftest.$ac_ext >&5'
ac_link='$CC -o conftest$ac_exeext $CFLAGS $CPPFLAGS $LDFLAGS conftest.$ac_ext $LIBS >&5'
ac_compiler_gnu=$ac_cv_c_compiler_gnu
{ $as_echo "$as_me:${as_lineno-$LINENO}: checking how to run the C preprocessor" >&5
$as_echo_n "checking how to run the C preprocessor... " >&6; }
# On Suns, sometimes $CPP names a directory.
if test -n "$CPP" && test -d "$CPP"; then
  CPP=
