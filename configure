  VIC_KERNEL_CPPFLAGS="$VIC_KERNEL_CPPFLAGS $source_dir/$rel_file"
fi
			;;
		*)
			# If we don't know what it is, add it, just to
			# be conservative.
			VIC_KERNEL_CPPFLAGS="$VIC_KERNEL_CPPFLAGS $token"
			;;
		esac
	done

